rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only authenticated users can read/write any data
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Candidates - authenticated read/write
    match /candidates/{type}/list/{candidateId} {
      allow read, write: if request.auth != null;
    }

    // Processed emails
    match /emails/processedEmails/list/{emailId} {
      allow read, write: if request.auth != null;
    }

    // Config
    match /config/{docId} {
      allow read, write: if request.auth != null;
    }

    // Settings - authenticated only
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
